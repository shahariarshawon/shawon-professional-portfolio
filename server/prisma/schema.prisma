generator client {
  provider     = "prisma-client-js"
  // output       = "../src/generated/prisma"
  // moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum ExperienceStatus {
  CURRENTLY_WORKING
  COMPLETED
}

enum ContactMessageStatus {
  UNREAD
  READ
}

enum ResumeTargetRole {
  BACKEND_DEVELOPER
  FULL_STACK_DEVELOPER
  SOFTWARE_ENGINEER
}

enum FileType {
  IMAGE
  PDF
  OTHER
}

model AdminUser {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      AdminRole @default(ADMIN)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admin_users")
}

model NavbarItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  order     Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("navbar_items")
}

model HeroSection {
  id                      String   @id @default(cuid())
  name                    String
  designation             String
  introduction            String   @db.Text
  photoUrl                String?
  resumeUrl               String?
  isGetInTouchEnabled     Boolean  @default(true)
  isViewResumeEnabled     Boolean  @default(true)
  isDownloadResumeEnabled Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  badges         HeroBadge[]
  techHighlights HeroTechHighlight[]
  socialLinks    SocialLink[]

  @@map("hero_sections")
}

model HeroBadge {
  id        String      @id @default(cuid())
  text      String
  order     Int         @default(0)
  isEnabled Boolean     @default(true)
  heroId    String
  hero      HeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("hero_badges")
}

model HeroTechHighlight {
  id        String      @id @default(cuid())
  name      String
  order     Int         @default(0)
  isEnabled Boolean     @default(true)
  heroId    String
  hero      HeroSection @relation(fields: [heroId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("hero_tech_highlights")
}

model SocialLink {
  id        String       @id @default(cuid())
  platform  String
  url       String
  icon      String?
  order     Int          @default(0)
  isEnabled Boolean      @default(true)
  heroId    String?
  hero      HeroSection? @relation(fields: [heroId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("social_links")
}

model AboutSection {
  id                 String   @id @default(cuid())
  currentStatus      String   @db.Text
  programmingJourney String   @db.Text
  workEnjoyment      String   @db.Text
  backendInterest    String   @db.Text
  futurePlan         String   @db.Text
  personality        String   @db.Text
  hobbies            String?  @db.Text
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  quickFacts QuickFact[]

  @@map("about_sections")
}

model QuickFact {
  id        String       @id @default(cuid())
  label     String
  value     String       @db.Text
  order     Int          @default(0)
  isEnabled Boolean      @default(true)
  aboutId   String
  about     AboutSection @relation(fields: [aboutId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("quick_facts")
}

model Experience {
  id          String           @id @default(cuid())
  companyName String
  role        String
  status      ExperienceStatus @default(COMPLETED)
  startDate   String
  endDate     String?
  location    String?
  description String           @db.Text
  companyLogo String?
  order       Int              @default(0)
  isEnabled   Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  bullets ExperienceBullet[]
  metrics ExperienceMetric[]

  @@map("experiences")
}

model ExperienceBullet {
  id           String     @id @default(cuid())
  text         String     @db.Text
  order        Int        @default(0)
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("experience_bullets")
}

model ExperienceMetric {
  id           String     @id @default(cuid())
  label        String
  value        String
  order        Int        @default(0)
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("experience_metrics")
}

model SkillCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills Skill[]

  @@map("skill_categories")
}

model Skill {
  id         String        @id @default(cuid())
  name       String
  iconUrl    String?
  level      Int?
  order      Int           @default(0)
  isEnabled  Boolean       @default(true)
  categoryId String
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("skills")
}

model Project {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  shortDescription      String   @db.Text
  fullDescription       String?  @db.Text
  purpose               String?  @db.Text
  targetUsers           String?  @db.Text
  uniqueCapabilities    String?  @db.Text
  techStack             String[]
  liveLink              String?
  githubLink            String?
  clientGithubLink      String?
  backendGithubLink     String?
  demoCredentials       String?  @db.Text
  authenticationDetails String?  @db.Text
  isFeatured            Boolean  @default(false)
  isEnabled             Boolean  @default(true)
  order                 Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  images       ProjectImage[]
  features     ProjectFeature[]
  challenges   ProjectChallenge[]
  improvements ProjectImprovement[]

  @@map("projects")
}

model ProjectImage {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  fileType  FileType @default(IMAGE)
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_images")
}

model ProjectFeature {
  id        String   @id @default(cuid())
  title     String?
  text      String   @db.Text
  type      String? // general, backend, frontend, database
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_features")
}

model ProjectChallenge {
  id        String   @id @default(cuid())
  challenge String   @db.Text
  solution  String?  @db.Text
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_challenges")
}

model ProjectImprovement {
  id          String   @id @default(cuid())
  improvement String   @db.Text
  order       Int      @default(0)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("project_improvements")
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  duration    String
  location    String?
  description String?  @db.Text
  order       Int      @default(0)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("educations")
}

model Certification {
  id                  String   @id @default(cuid())
  name                String
  issuingOrganization String
  issueDate           String?
  credentialId        String?
  credentialLink      String?
  certificateFileUrl  String?
  order               Int      @default(0)
  isEnabled           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("certifications")
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  icon        String?
  order       Int      @default(0)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("services")
}

model ContactInfo {
  id        String   @id @default(cuid())
  email     String
  phone     String?
  whatsapp  String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_info")
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String               @db.Text
  status    ContactMessageStatus @default(UNREAD)
  ipAddress String?
  userAgent String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@map("contact_messages")
}

model Resume {
  id          String           @id @default(cuid())
  title       String
  targetRole  ResumeTargetRole
  isActive    Boolean          @default(false)
  name        String
  designation String
  email       String
  phone       String?
  location    String?
  linkedin    String?
  github      String?
  portfolio   String?
  summary     String           @db.Text
  language    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  sections ResumeSection[]
  projects ResumeProject[]
  skills   ResumeSkill[]

  @@map("resumes")
}

model ResumeSection {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int      @default(0)
  isEnabled Boolean  @default(true)
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resume_sections")
}

model ResumeProject {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  techStack   String[]
  liveLink    String?
  githubLink  String?
  order       Int      @default(0)
  resumeId    String
  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("resume_projects")
}

model ResumeSkill {
  id        String   @id @default(cuid())
  category  String
  skills    String[]
  order     Int      @default(0)
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("resume_skills")
}

model SiteSetting {
  id                   String   @id @default(cuid())
  siteTitle            String
  seoTitle             String?
  seoDescription       String?  @db.Text
  seoKeywords          String[]
  accentColor          String   @default("#599692")
  backgroundColor      String   @default("#11172a")
  normalTextColor      String   @default("#626c7d")
  highlightedTextColor String   @default("#dfe5ec")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("site_settings")
}

model FooterLink {
  id        String   @id @default(cuid())
  label     String
  href      String
  order     Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("footer_links")
}
